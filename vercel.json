{
  "version": 2,
  "name": "birthday-wish",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/pages/index.html" },
    { "source": "/login", "destination": "/pages/index.html" },
    { "source": "/register", "destination": "/pages/index.html" },
    { "source": "/dashboard", "destination": "/pages/dashboard.html" },
    { "source": "/create", "destination": "/pages/create.html" },
    { "source": "/view", "destination": "/pages/view.html" }
  ],
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
